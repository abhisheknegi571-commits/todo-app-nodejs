<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Task List</title>
  <link rel="stylesheet" href="/styles.css">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&display=swap');

    *, *::before, *::after {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #0d0f14;
      color: #eef0f7;
      min-height: 100vh;
    }

    /* ── WRAPPER ── */
    .task-wrapper {
      width: 100%;
      max-width: 780px;
      margin: 36px auto 60px;
      padding: 0 20px;
    }

    /* ── PAGE TITLE ── */
    .page-heading {
      font-family: 'Syne', sans-serif;
      font-size: 1.6rem;
      font-weight: 800;
      color: #eef0f7;
      margin-bottom: 24px;
      letter-spacing: -0.4px;
    }

    .page-heading span {
      font-size: 0.85rem;
      font-weight: 400;
      color: #4a5070;
      font-family: 'DM Sans', sans-serif;
      margin-left: 10px;
      letter-spacing: 0;
    }

    /* ── TASK CARD ── */
    .task-container {
      background: #13161e;
      border: 1px solid rgba(255,255,255,0.07);
      border-radius: 14px;
      padding: 20px 22px;
      margin-bottom: 14px;
      transition: transform 0.22s, border-color 0.22s, box-shadow 0.22s;
    }

    .task-container:hover {
      transform: translateY(-3px);
      border-color: rgba(91,141,238,0.25);
      box-shadow: 0 8px 32px rgba(0,0,0,0.3);
    }

    .task-container.is-completed {
      opacity: 0.55;
    }

    /* ── TASK HEADER ── */
    .task-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
    }

    .task-header h3 {
      font-family: 'Syne', sans-serif;
      font-size: 1rem;
      font-weight: 700;
      color: #eef0f7;
      line-height: 1.4;
    }

    .task-header h3.completed-task {
      text-decoration: line-through;
      color: #4a5070;
    }

    /* ── PRIORITY BADGE ── */
    .priority {
      padding: 3px 11px;
      border-radius: 20px;
      font-size: 0.7rem;
      font-weight: 500;
      white-space: nowrap;
      flex-shrink: 0;
    }

    .priority.high   { background: rgba(241,102,102,0.12); color: #f16666; border: 1px solid rgba(241,102,102,0.2); }
    .priority.medium { background: rgba(245,166,35,0.12);  color: #f5a623; border: 1px solid rgba(245,166,35,0.2); }
    .priority.low    { background: rgba(62,207,142,0.12);  color: #3ecf8e; border: 1px solid rgba(62,207,142,0.2); }

    /* ── DESCRIPTION ── */
    .task-desc {
      font-size: 0.85rem;
      color: #7a82a0;
      margin-top: 10px;
      line-height: 1.6;
    }

    /* ── DATE ── */
    .task-date {
      font-size: 0.72rem;
      color: #4a5070;
      margin-top: 10px;
    }

    /* ── FOOTER ── */
    .task-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-top: 16px;
      flex-wrap: wrap;
      gap: 10px;
    }

    /* ── BUTTONS ── */
    .btn-group {
      display: flex;
      gap: 8px;
    }

    .edit-btn,
    .delete-btn {
      font-family: 'DM Sans', sans-serif;
      font-size: 0.78rem;
      font-weight: 500;
      padding: 6px 14px;
      border-radius: 8px;
      text-decoration: none;
      transition: background 0.2s, box-shadow 0.2s;
    }

    .edit-btn {
      background: rgba(91,141,238,0.12);
      color: #5b8dee;
      border: 1px solid rgba(91,141,238,0.25);
    }

    .edit-btn:hover {
      background: rgba(91,141,238,0.22);
      box-shadow: 0 0 10px rgba(91,141,238,0.2);
    }

    .delete-btn {
      background: rgba(241,102,102,0.1);
      color: #f16666;
      border: 1px solid rgba(241,102,102,0.2);
    }

    .delete-btn:hover {
      background: rgba(241,102,102,0.2);
      box-shadow: 0 0 10px rgba(241,102,102,0.15);
    }

    /* ── CHECKBOX ── */
    .complete-box {
      display: flex;
      align-items: center;
      gap: 7px;
      font-size: 0.78rem;
      color: #7a82a0;
      cursor: pointer;
    }

    .complete-box input[type="checkbox"] {
      width: 16px;
      height: 16px;
      accent-color: #3ecf8e;
      cursor: pointer;
    }

    /* ── EMPTY STATE ── */
    .empty-state {
      text-align: center;
      padding: 80px 20px;
    }

    .empty-state h2 {
      font-family: 'Syne', sans-serif;
      font-size: 1.4rem;
      font-weight: 800;
      color: #eef0f7;
      margin-bottom: 8px;
    }

    .empty-state p {
      font-size: 0.85rem;
      color: #4a5070;
      margin-bottom: 24px;
    }

    .add-first-task {
      display: inline-block;
      font-family: 'DM Sans', sans-serif;
      font-size: 0.9rem;
      font-weight: 500;
      color: #fff;
      background: #5b8dee;
      padding: 10px 24px;
      border-radius: 9px;
      text-decoration: none;
      transition: background 0.22s, box-shadow 0.22s;
    }

    .add-first-task:hover {
      background: #7aa5f5;
      box-shadow: 0 0 18px rgba(91,141,238,0.3);
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 600px) {
      .task-wrapper {
        margin: 20px auto 40px;
        padding: 0 14px;
      }

      .task-footer {
        flex-direction: column;
        align-items: flex-start;
      }

      .page-heading {
        font-size: 1.3rem;
      }
    }
  </style>
</head>
<body>

  <%- include('navbar') %>

  <div class="task-wrapper">

    <h2 class="page-heading">
      My Tasks
      <span><%= tasks.length %> task<%= tasks.length !== 1 ? 's' : '' %></span>
    </h2>

    <% if(tasks.length === 0){ %>

      <div class="empty-state">
        <h2>No tasks yet</h2>
        <p>Start by adding your first task</p>
        <a href="/add" class="add-first-task">+ Add Task</a>
      </div>

    <% } else { %>

      <% tasks.forEach(task => { %>

        <div class="task-container <%= task.status === 'completed' ? 'is-completed' : '' %>">

          <div class="task-header">
            <h3 class="<%= task.status === 'completed' ? 'completed-task' : '' %>">
              <%= task.title %>
            </h3>
            <span class="priority <%= task.priority.toLowerCase() %>">
              <%= task.priority %>
            </span>
          </div>

          <p class="task-desc"><%= task.description %></p>

          <p class="task-date">
            📅 <%= task.createdAt ? new Date(task.createdAt).toLocaleString("en-IN") : "" %>
          </p>

          <div class="task-footer">
            <div class="btn-group">
              <a class="edit-btn" href="/update/<%= task._id %>">Edit</a>
              <a class="delete-btn" href="/delete/<%= task._id %>">Delete</a>
            </div>

            <div class="complete-box">
              <input
                type="checkbox"
                <%= task.status === "completed" ? "checked" : "" %>
                onclick="window.location.href='/complete/<%= task._id %>'"
              />
              <label>Completed</label>
            </div>
          </div>

        </div>

      <% }) %>

    <% } %>

  </div>

</body>
</html>
